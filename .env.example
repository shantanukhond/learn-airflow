# Copy to .env and adjust as needed:
#   cp .env.example .env

# Docker Compose settings (not Airflow runtime config)
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.2
AIRFLOW_PROJ_DIR=.

# Admin user created on first init (FAB auth manager)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Extra pip packages installed at container start (comma-separated, no spaces)
# _PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-amazon,requests
